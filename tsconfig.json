{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleDetection": "force",
    "rootDir": ".",
    "module": "preserve",
    "paths": {
      "unhead": ["./packages/unhead/src/index"],
      "unhead/client": ["./packages/unhead/src/client/index"],
      "unhead/server": ["./packages/unhead/src/server/index"],
      "unhead/plugins": ["./packages/unhead/src/plugins/index"],
      "unhead/legacy": ["./packages/unhead/src/legacy/index"],
      "unhead/minify": ["./packages/unhead/src/minify/index"],
      "unhead/parser": ["./packages/unhead/src/parser/index"],
      "unhead/scripts": ["./packages/unhead/src/scripts/index"],
      "unhead/utils": ["./packages/unhead/src/utils/index"],
      "unhead/types": ["./packages/unhead/src/types/index"],
      "unhead/validate": ["./packages/unhead/src/validate/index"],
      "unhead/stream/client": ["./packages/unhead/src/stream/client"],
      "unhead/stream/server": ["./packages/unhead/src/stream/server"],
      "unhead/stream/unplugin": ["./packages/unhead/src/stream/unplugin"],
      "unhead/stream/iife": ["./packages/unhead/src/stream/iife-code"],
      "@unhead/ssr": ["./packages/unhead/src/server/index"],
      "@unhead/dom": ["./packages/unhead/src/client/index"],
      "@unhead/vue": ["./packages/vue/src/index"],
      "@unhead/vue/client": ["./packages/vue/src/client"],
      "@unhead/vue/server": ["./packages/vue/src/server"],
      "@unhead/bundler": ["./packages/bundler/src/index"],
      "@unhead/bundler/vite": ["./packages/bundler/src/unplugin/vite"],
      "@unhead/bundler/framework": ["./packages/bundler/src/unplugin/framework"],
      "@unhead/schema-org": ["./packages/schema-org/src/index"],
      "@unhead/schema-org/imports": ["./packages/schema-org/src/imports"],
      "@unhead/schema-org/vue": ["./packages/schema-org/src/vue/index"],
      "@unhead/schema-org/vue/meta": ["./packages/schema-org/src/vue/meta"],
      "@unhead/svelte/types": ["./packages/svelte/src/types"],
      "@unhead/angular": ["./packages/angular/src/index"],
      "@unhead/angular/client": ["./packages/angular/client/src/index"],
      "@unhead/angular/server": ["./packages/angular/server/src/index"]
    },
    "resolveJsonModule": true,
    "types": ["vitest/globals"],
    "strict": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "declaration": true,
    "skipLibCheck": true
  },
  "exclude": [
    "examples",
    "bench",
    "packages/angular",
    "packages/devtools-app"
  ]
}
